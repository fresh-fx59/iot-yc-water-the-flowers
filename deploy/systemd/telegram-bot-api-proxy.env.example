# Bind settings
TELEGRAM_PROXY_HOST=0.0.0.0
TELEGRAM_PROXY_PORT=16443

# Optional bearer auth checked by proxy (recommended)
TELEGRAM_PROXY_AUTH_TOKEN=replace_with_long_random_token

# Upstream timeout in seconds for api.telegram.org requests
TELEGRAM_PROXY_TIMEOUT_SEC=20

# TLS cert/key for HTTPS listener on custom port (required for ESP32 https base URL)
TELEGRAM_PROXY_TLS_CERT_FILE=/etc/letsencrypt/live/monitoring.example.com/fullchain.pem
TELEGRAM_PROXY_TLS_KEY_FILE=/etc/letsencrypt/live/monitoring.example.com/privkey.pem
